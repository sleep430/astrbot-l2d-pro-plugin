# 生产环境配置（会覆盖 .env 中同名变量）

# 服务器连接配置
VITE_DEFAULT_SERVER_URL=ws://127.0.0.1:9090/astrbot/live2d
VITE_DEFAULT_TOKEN=

# 应用信息
VITE_APP_TITLE=AstrBot Live2D Pro
VITE_APP_VERSION=1.1.0

# 生产环境建议配置
VITE_ENABLE_DEVTOOLS=false
VITE_LOG_LEVEL=error

# Wake word (Porcupine, offline, 预留配置，当前版本未启用)
VITE_PORCUPINE_ACCESS_KEY=
VITE_PORCUPINE_MODULE_PATH=./wakeword/porcupine/porcupine.js
VITE_PORCUPINE_MODEL_PATH=./wakeword/porcupine_params.pv
VITE_PORCUPINE_KEYWORD_BASE_PATH=./wakeword/keywords
